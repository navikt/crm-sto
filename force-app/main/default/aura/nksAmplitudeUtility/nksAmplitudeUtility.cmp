<aura:component implements="flexipage:availableForAllPageTypes" controller="FeatureToggleAura">
    <aura:attribute name="isBobEnabled" type="Boolean" default="false" />
    <aura:handler name="init" value="{!this}" action="{!c.getBobFeature}" />
    <!--<c:amplitudeBackground aura:id="amplitudeBackground"></c:amplitudeBackground>-->
    <c:nksGetStoUtility aura:id="stoUtility"></c:nksGetStoUtility>
    <aura:if isTrue="{!v.isBobEnabled}">
        <c:bobUsageWrapper />
    </aura:if>
</aura:component>
